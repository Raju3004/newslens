# Get a free key: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your_key_here

# Optional. "test" works for free, low-volume use (default if left blank).
# Get your own free key at: open-platform.theguardian.com/access
GUARDIAN_API_KEY=test

# Optional. Defaults to claude-sonnet-5. Use claude-haiku-4-5-20251001 for a
# cheaper/faster model if you're running many searches during development.
CLAUDE_MODEL=claude-sonnet-5

PORT=3000
